# ============================================================
# 应用基础配置
# ============================================================
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
PROJECT_NAME=Test-Project

# 安全密钥（生产环境必须替换！生成命令：openssl rand -hex 32）
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# 数据库类型：mysql 或 dameng（切换后重启服务）
# ============================================================
DB_TYPE=mysql

# ============================================================
# MySQL 配置（DB_TYPE=mysql 时生效）
# ============================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mydb
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE=3600

# ============================================================
# 达梦数据库配置（DB_TYPE=dameng 时生效）
# 注意：需要单独安装 dmPython 驱动和 sqlalchemy-dm
# ============================================================
DM_HOST=localhost
DM_PORT=5236
DM_USER=SYSDBA
DM_PASSWORD=SYSDBA001
DM_DATABASE=SYSDBA
DM_POOL_SIZE=10
DM_MAX_OVERFLOW=20
DM_POOL_RECYCLE=3600
